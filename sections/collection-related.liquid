{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
COLLECTION RELATED LINKS
----------------------------------------------------------------------------------------------------------------------
Renders related categories and pSEO page links for collection pages.
Provides sibling collection links + style guide and comparison cross-links.
{%- endcomment -%}

{%- assign has_links = false -%}
{%- for block in section.blocks -%}
  {%- if block.settings.link_url != blank -%}
    {%- assign has_links = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if has_links -%}
  <div class="section-spacing color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
    <div class="container container--{{ section.settings.content_width }}">
      <div class="section-stack">
        {%- if section.settings.heading != blank -%}
          <div class="section-header">
            <h2 class="h4">{{ section.settings.heading }}</h2>
            {%- if section.settings.subheading != blank -%}
              <p class="text-subdued">{{ section.settings.subheading }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="collection-related__grid">
          {%- for block in section.blocks -%}
            {%- if block.settings.link_url != blank -%}
              <a href="{{ block.settings.link_url }}" class="collection-related__card" {{ block.shopify_attributes }}>
                {%- if block.settings.link_label != blank -%}
                  <span class="collection-related__label text-subdued">{{ block.settings.link_label }}</span>
                {%- endif -%}
                <h3 class="h6">{{ block.settings.link_title }}</h3>
                {%- if block.settings.link_description != blank -%}
                  <p class="text-subdued text-sm">{{ block.settings.link_description }}</p>
                {%- endif -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  <style>
    .collection-related__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: var(--spacing-4, 16px);
    }
    .collection-related__card {
      display: block;
      padding: var(--spacing-5, 20px);
      border: 1px solid rgb(var(--text-color) / 0.12);
      border-radius: var(--rounded-sm, 6px);
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, background 0.2s;
    }
    .collection-related__card:hover {
      border-color: rgb(var(--text-color) / 0.3);
      background: rgb(var(--background-secondary, 245 245 245));
    }
    .collection-related__card h3 {
      margin-bottom: var(--spacing-1, 4px);
    }
    .collection-related__label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Collection Related",
  "class": "shopify-section--collection-related",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore More"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ],
      "default": "md"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "link_label",
          "label": "Label (e.g. Style Guide, Comparison, Related Category)"
        },
        {
          "type": "text",
          "id": "link_title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "link_description",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Related"
    }
  ]
}
{% endschema %}
