{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
CROSS-LINKS SECTION
----------------------------------------------------------------------------------------------------------------------

A reusable section for internal linking. Renders a grid of manually curated link cards.
Can be added to any template via the theme customizer for SEO internal linking.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  <div class="section-spacing color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
    <div class="container container--{{ section.settings.content_width }}">
      <div class="section-stack">
        {%- if section.settings.heading != blank -%}
          <div class="section-header">
            <h2 class="h4">{{ section.settings.heading }}</h2>
            {%- if section.settings.subheading != blank -%}
              <p class="text-subdued">{{ section.settings.subheading }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="cross-links-grid">
          {%- for block in section.blocks -%}
            {%- if block.settings.link_url != blank -%}
              <a href="{{ block.settings.link_url }}" class="cross-links__card" {{ block.shopify_attributes }}>
                <h3 class="h6">{{ block.settings.link_title }}</h3>
                {%- if block.settings.link_description != blank -%}
                  <p class="text-subdued text-sm">{{ block.settings.link_description }}</p>
                {%- endif -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  <style>
    .cross-links-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: var(--spacing-4, 16px);
    }
    .cross-links__card {
      display: block;
      padding: var(--spacing-5, 20px);
      border: 1px solid rgb(var(--text-color) / 0.12);
      border-radius: var(--rounded-sm, 6px);
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s;
    }
    .cross-links__card:hover {
      border-color: rgb(var(--text-color) / 0.3);
    }
    .cross-links__card h3 {
      margin-bottom: var(--spacing-1, 4px);
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Cross Links",
  "class": "shopify-section--cross-links",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore More"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ],
      "default": "md"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link Card",
      "settings": [
        {
          "type": "text",
          "id": "link_title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "link_description",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cross Links"
    }
  ]
}
{% endschema %}
