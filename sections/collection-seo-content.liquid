{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
COLLECTION SEO CONTENT
----------------------------------------------------------------------------------------------------------------------
Rich SEO content section for collection pages. Renders below the product grid
with buying guide text, style tips, and cross-links to pSEO pages.
{%- endcomment -%}

{%- if section.settings.content != blank or section.settings.heading != blank -%}
  <div class="section-spacing color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
    <div class="container container--{{ section.settings.content_width }}">
      <div class="section-stack">
        {%- if section.settings.heading != blank -%}
          <div class="section-header">
            <h2 class="h3">{{ section.settings.heading }}</h2>
            {%- if section.settings.subheading != blank -%}
              <p class="text-subdued">{{ section.settings.subheading }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.content != blank -%}
          <div class="prose" style="max-width: 780px;">
            {{ section.settings.content }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Collection SEO Content",
  "class": "shopify-section--collection-seo-content",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buying Guide"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "SEO content",
      "info": "Rich text buying guide, style tips, or category information for SEO."
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ],
      "default": "md"
    }
  ],
  "presets": [
    {
      "name": "Collection SEO Content"
    }
  ]
}
{% endschema %}
