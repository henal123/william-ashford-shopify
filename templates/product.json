        "remove_horizontal_spacing": false,
        "liquid": "<div class=\"kyx-product-tabs\">\n\n  <div class=\"kyx-tabs-header\">\n    <button class=\"kyx-tab active\" data-tab=\"details\">Marketed by</button>\n    <button class=\"kyx-tab\" data-tab=\"washcare\">Return and Exchange Policy</button>\n    <button class=\"kyx-tab\" data-tab=\"shipping\">Place Return/Exchange</button>\n  </div>\n\n  <div class=\"kyx-tabs-content\">\n\n    <!-- MARKETED BY -->\n    <div class=\"kyx-tab-panel active\" id=\"details\">\n      <strong>William Ashford</strong><br>\n      Plot No. 79 Doctor Feroz Lane, SVCIE Phase 3 Rd, Balanagar, Hyderabad, Telangana 500037<br>\n      Phone: 8500093233<br>\n      Email: info.williamashford@gmail.com\n    </div>\n\n    <!-- RETURN POLICY -->\n    <div class=\"kyx-tab-panel\" id=\"washcare\">\n      <p><strong>We offer hassle-free 7 days returns and exchange.</strong></p>\n\n      <p>\n      We offer 7 days hassle-free returns & exchange from the date of delivery.\n      We also offer reverse pick-up services.\n      </p>\n\n      <p>\n      For prepaid orders, refunds are processed to the original payment method.\n      For COD orders, a refund link will be sent via WhatsApp, SMS, and Email from Razorpay.\n      </p>\n\n      <p>\n      Once the product is picked up, we initiate the refund within 24 hours.\n      The amount reflects in your bank account within 5–7 working days (usually earlier).\n      </p>\n\n      <p>\n      To place a Return & Exchange request, please click here.\n      For more details on our Returns/Exchange Policies, please contact support.\n      </p>\n    </div>\n\n    <!-- PLACE RETURN -->\n    <div class=\"kyx-tab-panel\" id=\"shipping\">\n      To place any return or exchange,\n      <a href=\"https://williamashford.in/apps/return_prime\" class=\"kyx-account-link\">Go to Return/exchange page</a>.\n    </div>\n\n  </div>\n</div>\n\n<style>\n.kyx-product-tabs {\n  background: #f4f4f4;\n  border: 1px solid #e0e0e0;\n  border-radius: 18px;\n  margin-top: 30px;\n  overflow: hidden;\n}\n\n.kyx-tabs-header {\n  display: flex;\n  border-bottom: 1px solid #e0e0e0;\n  padding: 0 20px;\n}\n\n.kyx-tab {\n  flex: 1;\n  background: transparent;\n  border: none;\n  padding: 18px 10px;\n  font-size: 15px;\n  font-weight: 500;\n  color: #777;\n  cursor: pointer;\n  position: relative;\n}\n\n.kyx-tab.active {\n  color: #000;\n  font-weight: 600;\n}\n\n.kyx-tab.active::after {\n  content: \"\";\n  position: absolute;\n  bottom: -1px;\n  left: 20%;\n  width: 60%;\n  height: 3px;\n  background: #999;\n  border-radius: 2px;\n}\n\n.kyx-tabs-content {\n  padding: 25px 30px;\n  font-size: 14px;\n  line-height: 1.7;\n}\n\n.kyx-tab-panel {\n  display: none;\n}\n\n.kyx-tab-panel.active {\n  display: block;\n}\n\n/* Account Link */\n.kyx-account-link{\n  font-weight: 600;\n  text-decoration: underline;\n  color: #000;\n}\n\n.kyx-account-link:hover{\n  opacity: 0.7;\n}\n</style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function() {\n  document.querySelectorAll(\".kyx-product-tabs\").forEach(function(container) {\n\n    const tabs = container.querySelectorAll(\".kyx-tab\");\n    const panels = container.querySelectorAll(\".kyx-tab-panel\");\n\n    tabs.forEach(function(tab) {\n      tab.addEventListener(\"click\", function() {\n\n        const target = tab.getAttribute(\"data-tab\");\n\n        tabs.forEach(t => t.classList.remove(\"active\"));\n        panels.forEach(p => p.classList.remove(\"active\"));\n\n        tab.classList.add(\"active\");\n        container.querySelector(\"#\" + target).classList.add(\"active\");\n\n      });\n    });\n\n  });\n});\n</script>",
        "text_alignment": "center"
      }
    },
